# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Public base URL for images, for example:
# https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# or a custom domain later.
R2_PUBLIC_BASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron authentication (use a random value with at least 32 characters)
CRON_SECRET=

# Admin session
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=

# Optional guardrails
MAX_UPLOAD_BYTES=6291456

# Local/demo only. Production defaults to disabling sample-data fallback.
ALLOW_DEMO_FALLBACK=
